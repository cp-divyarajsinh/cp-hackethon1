# Put this file in the project root (same folder as package.json), OR copy to server/.env
# Required for upload pipeline (Whisper transcription + OpenAI analysis)
OPENAI_API_KEY=sk-...
# Optional: chat model for /api/analyze (default: gpt-4o-mini)
# OPENAI_ANALYSIS_MODEL=gpt-4o-mini

# Login (defaults: admin / password123)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=password123
# Stateless session signing — set a long random string in production
# AUTH_SECRET=change-me-to-a-long-random-string

# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Client (create client/.env)
VITE_API_URL=http://localhost:3001
